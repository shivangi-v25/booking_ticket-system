<!doctype html>
<html lang="en">
  <head>
    <title>CinePass | Create Your Account</title>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: radial-gradient(circle at center, #1e293b 0%, #232a3b 100%);
        font-family: sans-serif;
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .form-floating label {
        color: #7a828f !important;
      }
    </style>
  </head>

  <body class="min-vh-100 d-flex align-items-center text-white">
    <main class="container">
      <div class="col-12 col-md-8 col-lg-6 col-xl-5 mx-auto">
        <div class="glass-card p-5 shadow-lg rounded-4">
          <div class="text-center mb-5">
            <h2 class="fw-bold text-danger mb-1">
              <i class="fa-solid fa-ticket me-2"></i>CINEPASS
            </h2>
          </div>

          <form action="/register" method="post">
            <div class="form-floating text-dark mb-3">
              <input
                type="text"
                class="form-control rounded-3"
                name="name"
                id="regName"
                placeholder="John Doe"
                required
              />
              <label for="regName">Full Name</label>
            </div>

            <div class="form-floating text-dark mb-3">
              <input
                type="email"
                class="form-control rounded-3"
                name="email"
                id="regEmail"
                placeholder="name@example.com"
                required
              />
              <label for="regEmail">Email address</label>
            </div>

            <div class="form-floating text-dark mb-4">
              <input
                type="password"
                class="form-control rounded-3"
                name="password"
                id="regPass"
                placeholder="Password"
                required
              />
              <label for="regPass">Password</label>
            </div>

            <button
              type="submit"
              class="btn btn-danger w-100 py-3 rounded-3 fw-bold text-uppercase tracking-wider"
            >
              Register Now
            </button>
          </form>

          <div class="text-center mt-4">
            <p class="text-secondary small">
              Already have an account?
              <a href="/login" class="text-danger text-decoration-none fw-bold"
                >Sign In</a
              >
            </p>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
