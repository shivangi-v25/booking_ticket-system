<!doctype html>
<html lang="en">

<head>
  <title>My Bookings | CinePass</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #0f172a; 
      color: #ffffff;
      min-height: 100vh;
    }

    .navbar {
      background-color: rgba(15, 23, 42, 0.95) !important;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .navbar-brand { font-weight: 700; color: #ef4444 !important; }

    
    .ticket-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      transition: all 0.3s ease;
      position: relative;
    }

    .ticket-card:hover {
      transform: translateY(-5px);
      border-color: #ef4444;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .poster-img {
      height: 100%;
      min-height: 220px;
      object-fit: cover;
      border-radius: 20px 0 0 20px;
    }

    .label-text {
      font-size: 0.7rem;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .value-text {
      font-weight: 600;
      color: #f1f5f9;
    }

    
    .ticket-divider {
      border-left: 2px dashed rgba(255, 255, 255, 0.1);
      height: 80%;
      margin: auto 0;
    }

    .btn-cancel {
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      transition: 0.3s;
    }

    @media (max-width: 576px) {
      .poster-img { border-radius: 20px 20px 0 0; }
      .ticket-divider { display: none; }
    }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-sm navbar-dark sticky-top">
      <div class="container">
        <a class="navbar-brand" href="/home"><i class="fa-solid fa-film me-2"></i>CINEPASS</a>
        <div class="collapse navbar-collapse" id="collapsibleNavId">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link" href="/home">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link active" href="/movies/booking text-white">History</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <div class="container my-5">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase tracking-widest">Booking History</h2>
        
      </div>

      <div class="row g-4 justify-content-center">
        <% if (book && book.length > 0) { %>
          <% book.forEach(b => { %>
            <div class="col-lg-10 col-xl-8">
              <div class="card ticket-card shadow-lg border-0 overflow-hidden">
                <div class="row g-0">
                  <div class="col-sm-3">
                    <img src="<%= b.show.movie.poster %>" class="img-fluid poster-img" alt="Poster">
                  </div>

                  <div class="col-sm-6">
                    <div class="card-body p-4">
                      <div class="mb-3">
                        <span class="badge bg-danger mb-2 px-3 rounded-pill"><%= b.show.movie.genre %></span>
                        <h4 class="fw-bold mb-0 text-white"><%= b.show.movie.title %></h4>
                        <small class="text-muted">Booking ID: #<%= b._id.toString().slice(-6).toUpperCase() %></small>
                      </div>

                      <div class="row g-3">
                        <div class="col-6">
                          <p class="label-text mb-0">Date & Time</p>
                          <p class="value-text mb-0"><%= new Date(b.show.date).toLocaleDateString('en-GB') %> | <%= b.show.time %></p>
                        </div>
                        <div class="col-6">
                          <p class="label-text mb-0">Seats</p>
                          <p class="value-text mb-0"><%= b.Seats %>  </p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-sm-3 d-flex text-center">
                    <div class="ticket-divider"></div>
                    <div class="card-body d-flex flex-column justify-content-center align-items-center">
                      <p class="label-text mb-0">Amount Paid</p>
                      <h3 class="fw-bold text-success">₹<%= b.price %></h3>
                      
                      <form action="/movies/removeShow/<%=b._id%>?_method=delete" method="post" class="mt-3">
                        <button type="submit" class="btn btn-outline-danger btn-sm btn-cancel px-4" 
                                onclick="return confirm('Do you want to cancel this ticket?')">
                          <i class="fa-solid fa-trash-can me-1"></i> Cancel
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <i class="fa-solid fa-ticket-simple display-1 text-secondary opacity-25 mb-3"></i>
            <h3 class="text-muted">No tickets found</h3>
            <a href="/home" class="btn btn-danger rounded-pill px-4 mt-3">Book Your First Show</a>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>