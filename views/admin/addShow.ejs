<!doctype html>
<html lang="en">
  <head>
    <title>Add Movie</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
  </head>
  <link rel="stylesheet" href="/css/style.css">
  
  <body >
 <div id="wrapper">
        <aside id="sidebar-wrapper">
            <div class="sidebar-brand">
                <span class="text-primary">BOOKING</span>ADMIN
            </div>
            <nav class="mt-3">
                <a href="/admin/admindash" class="nav-link-custom ">
                    <i class="bi bi-grid-1x2-fill me-2"></i></i>Dashboard
                </a>
                <a href="/admin/movieAdd" class="nav-link-custom">
                    <i class="bi bi-plus-square me-2"></i> Add Movie
                </a>
                <a href="/admin/addShow" class="nav-link-custom active">
                    <i class="bi bi-calendar-plus me-2"></i> Add Show
                </a>
                <a href="/admin/allShow" class="nav-link-custom">
                    <i class="bi bi-collection-play me-2"></i> All Shows
                </a>
            </nav>
        </aside>

        <div id="page-content-wrapper">
            <header class="top-navbar d-flex align-items-center justify-content-between">
                 <button id="menu-btn" class="btn btn-primary d-md-none">☰</button>
                <h5 class="m-0 fw-bold text-muted">Show Management</h5>
                <div class="dropdown">
                    <a class="btn btn-outline-danger btn-sm px-4" href="/admin/logout">Logout</a>
                </div>
            </header>

            <main class="p-4">
                <div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h4 class="mb-0 fw-bold text-secondary">Add New Show</h4>
                    
                </div>
                
                <div class="card-body p-4">
                    <form action="/admin/addShow" method="post">
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Movie Selection</label>
                            <select class="form-select form-select-lg border-2" name="movie" required>
                                <option value="" disabled selected>Select a movie...</option>
                                <% Movie.forEach(movie => { %>
                                    <option value="<%= movie.id %>"><%= movie.title %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input type="date" class="form-control border-2" name="date" id="formId1" required />
                                    <label for="formId1">Date</label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control border-2" name="time" id="time" placeholder="eg 7:00 pm" required />
                                    <label for="time">Time (e.g. 7:00 PM)</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control border-2" name="availableSeats" id="Availseat" placeholder="20" required />
                                    <label for="Availseat">Total Seats</label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control border-2" name="price" id="price" placeholder="250" required />
                                    <label for="price">Ticket Price</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm py-3">
                                <i class="bi bi-plus-circle me-2"></i>Create Show
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

                    
                
            </main>
        </div>
    </div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
  document.getElementById("menu-btn").addEventListener("click", function () {
    document.getElementById("sidebar-wrapper").classList.toggle("active");
  });
     if (document.getElementById("sidebar-wrapper").classList.contains("active")) {
             document.getElementById("sidebar-wrapper").style.marginLeft = "260px";
        } else {
            document.getElementById("sidebar-wrapper").style.marginLeft = "0";
        }
 
  </script>
  </body>
</html>
