<!doctype html>
<html lang="en">
  <head>
    <title>Add Movie</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
<header>     <nav class="navbar navbar-expand-sm navbar-light bg-light">
        <div class="container">
          <a class="navbar-brand" href="/admindash">booking</a>
          <button
            class="navbar-toggler d-lg-none"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#collapsibleNavId"
            aria-controls="collapsibleNavId"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavId">
            <ul class="navbar-nav me-auto mt-2 mt-lg-0">
      
              <li class="nav-item">
                <a class="nav-link" href="/admin/movieAdd">Movie</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/addShow">SHow</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/allShow">All SHow</a>
              </li>
    
            </ul>
             <a
              name=""
              id=""
              class="btn btn-primary btn-sm"
              href="/admin/logout"
              role="button"
              >logout</a
             >
             
          </div>
        </div>
      </nav></header>
  <body>
    <div class="container mt-5">
      <h2 class="mb-4">edit Show</h2>

      <form action="/admin/editShow/<%=shows.id %>?_method=patch" method="post">
        <div class="mb-3">
          <label for="" class="form-label">Movie</label>
          <select class="form-select form-select-lg" name="movie" id="">
            <option selected value="<%=shows.movie.id %>"><%=shows.movie.title %></option>
            <%Movie.forEach(movie => { %>
                <option value="<%= movie.id %>" ><%=movie.title %></option>
            <% }); %>
            
          </select>
        </div>

        <div class="form-floating mb-3">
          <input
            type="date"
            class="form-control"
            name="date"
            id="formId1"
            placeholder=""
            value="<%=shows.date %>"
          />
          <label for="formId1">Date</label>
        </div>

        <div class="form-floating mb-3">
          <input
            type="text"
            class="form-control"
            name="time"
            id="time"
            placeholder="eg 7:00 pm"
            value="<%=shows.time %>"
          />
          <label for="time">time</label>
        </div>

        <div class="form-floating mb-3">
          <input
            type="number"
            class="form-control"
            name="availableSeats"
            id="Availseat"
            placeholder="20"
            value="<%=shows.availableSeats %>"
            required
          />
          <label for="Availseat">Available seats </label>
        </div>

        <div class="form-floating mb-3">
          <input
            type="number"
            class="form-control"
            name="price"
            id="price"
            placeholder="250"
            value="<%=shows.price %>"
            required
          />
          <label for="price">Ticket price</label>
        </div>


        <button type="submit" class="btn btn-primary">Submit</button>
      </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
  </body>
</html>
