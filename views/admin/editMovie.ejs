<!doctype html>
<html lang="en">
  <head>
    <title>Add Movie</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <div id="wrapper">
      <aside id="sidebar-wrapper">
        <div class="sidebar-brand">
          <span class="text-primary">BOOKING</span>ADMIN
        </div>
        <nav class="mt-3">
          <a href="/admin/admindash" class="nav-link-custom active">
            <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
          </a>
          <a href="/admin/movieAdd" class="nav-link-custom">
            <i class="bi bi-plus-square me-2"></i> Add Movie
          </a>
          <a href="/admin/addShow" class="nav-link-custom">
            <i class="bi bi-calendar-plus me-2"></i> Add Show
          </a>
          <a href="/admin/allShow" class="nav-link-custom">
            <i class="bi bi-collection-play me-2"></i> All Shows
          </a>
        </nav>
      </aside>

      <div id="page-content-wrapper">
        <header
          class="top-navbar d-flex align-items-center justify-content-between"
        >
          <button id="menu-btn" class="btn btn-primary d-md-none">☰</button>
          <h5 class="m-0 fw-bold text-muted">Movie Management</h5>
          <div class="dropdown">
            <a class="btn btn-outline-danger btn-sm px-4" href="/admin/logout"
              >Logout</a
            >
          </div>
        </header>

        <main class="p-4">
          <div class="container-fluid py-4">
            <div class="row justify-content-center">
              <div class="col-12 col-lg-9 col-xl-7">
                <div class="mb-4">
                  <h3 class="fw-bold text-dark">Edit Movie Details</h3>
                  <p class="text-muted small">
                    Update the information for
                    <strong><%= movie.title %></strong> below.
                  </p>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                  <div class="card-body p-4 p-md-5">
                    <form
                      action="/admin/editMovie/<%= movie.id %>?_method=patch"
                      method="post"
                    >
                      <div class="row">
                        <div class="col-md-7">
                          <div class="form-floating mb-3">
                            <input
                              type="text"
                              class="form-control border-2"
                              name="title"
                              id="title"
                              placeholder="Movie Title"
                              value="<%= movie.title %>"
                              required
                            />
                            <label for="title">Movie Title</label>
                          </div>

                          <div class="form-floating mb-3">
                            <textarea
                              class="form-control border-2"
                              name="description"
                              id="description"
                              placeholder="Description"
                              style="height: 140px"
                              required
                            >
<%= movie.description %></textarea
                            >
                            <label for="description"
                              >Description / Synopsis</label
                            >
                          </div>
                        </div>

                        <div class="col-md-5">
                          <div class="form-floating mb-3">
                            <input
                              type="text"
                              class="form-control border-2"
                              name="duration"
                              id="duration"
                              value="<%= movie.duration %>"
                              placeholder="Duration"
                              required
                            />
                            <label for="duration">Duration</label>
                          </div>

                          <div class="form-floating mb-3">
                            <input
                              type="text"
                              class="form-control border-2"
                              name="genre"
                              id="genre"
                              value="<%= movie.genre %>"
                              placeholder="Genre"
                              required
                            />
                            <label for="genre">Genre</label>
                          </div>

                          <div class="form-floating mb-3">
                            <input
                              type="text"
                              class="form-control border-2"
                              name="poster"
                              id="poster"
                              value="<%= movie.poster %>"
                              placeholder="Poster URL"
                              required
                            />
                            <label for="poster">Poster Image URL</label>
                          </div>
                        </div>
                      </div>

                      <hr class="my-4 text-secondary opacity-25" />

                      <div class="d-flex justify-content-end gap-2">
                        <a
                          href="/admin/admindash"
                          class="btn btn-light px-4 border"
                          >Cancel</a
                        >
                        <button
                          type="submit"
                          class="btn btn-primary px-5 fw-bold shadow-sm"
                        >
                          <i class="bi bi-arrow-repeat me-2"></i>Update Movie
                        </button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
    <script>
      document
        .getElementById("menu-btn")
        .addEventListener("click", function () {
          document.getElementById("sidebar-wrapper").classList.toggle("active");
        });
      if (
        document.getElementById("sidebar-wrapper").classList.contains("active")
      ) {
        document.getElementById("sidebar-wrapper").style.marginLeft = "260px";
      } else {
        document.getElementById("sidebar-wrapper").style.marginLeft = "0";
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
  </body>
</html>
