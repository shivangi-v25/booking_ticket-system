<!doctype html>
<html lang="en">
<head>
    <title>Booking Admin - Dashboard</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div id="wrapper">
        <aside id="sidebar-wrapper" >
            <div class="sidebar-brand">
                <span class="text-primary">BOOKING</span>ADMIN
            </div>
            <nav class="mt-3">
                <a href="/admin/admindash" class="nav-link-custom active">
                    <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
                </a>
                <a href="/admin/movieAdd" class="nav-link-custom">
                    <i class="bi bi-plus-square me-2"></i> Add Movie
                </a>
                <a href="/admin/addShow" class="nav-link-custom">
                    <i class="bi bi-calendar-plus me-2"></i> Add Show
                </a>
                <a href="/admin/allShow" class="nav-link-custom">
                    <i class="bi bi-collection-play me-2"></i> All Shows
                </a>
            </nav>
        </aside>

        <div id="page-content-wrapper">
            <header class="top-navbar d-flex align-items-center justify-content-between">
                 <button id="menu-btn" class="btn btn-primary d-md-none">
                          ☰
                    </button>
                <h5 class="m-0 fw-bold text-muted">Movie Management</h5>
                <div class="dropdown">
                    <a class="btn btn-outline-danger btn-sm px-4" href="/admin/logout">Logout</a>
                </div>
            </header>

            <main class="p-4">
                <div class="container-fluid">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6>Admin Dashboard</h6>
                        <span class="badge bg-primary px-3 py-2"><%= movies.length %> Movies Listed</span>
                    </div>

                    <div class="row g-4">
                        <% if (movies && movies.length > 0) { %>
                            <% movies.forEach(mov => { %>
                                <div class="col-sm-6 col-md-4 col-xl-3">
                                    <div class="movie-card shadow-sm h-100">
                                        <img class="card-img-top" src="<%=mov.poster%>" alt="<%= mov.title %>">
                                        <div class="card-body p-3">
                                            <div class="mb-2">
                                                <span class="genre-badge text-uppercase"><%= mov.genre %></span>
                                            </div>
                                            <h5 class="card-title fw-bold text-truncate"><%= mov.title %></h5>
                                            <p class="card-text text-muted small mb-3" style="height: 40px; overflow: hidden;">
                                                <%= mov.description %>
                                            </p>
                                            
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <span class="small text-muted"><i class="bi bi-clock me-1"></i> <%= mov.duration %></span>
                                            </div>

                                            <div class="d-flex gap-2">
                                                <a href="/admin/editMovie/<%=mov.id %>" class="btn btn-primary btn-sm flex-grow-1">
                                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                                </a>
                                                <form action="/admin/deleteMovie/<%=mov.id %>?_method=delete" method="post" class="flex-grow-1">
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                                        <i class="bi bi-trash me-1"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-film text-muted" style="font-size: 3rem;"></i>
                                <p class="mt-3 text-muted">No movies found in the database.</p>
                                <a href="/admin/movieAdd" class="btn btn-primary">Add Your First Movie</a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </main>
        </div>
    </div>
<script>
  document.getElementById("menu-btn").addEventListener("click", function () {
    document.getElementById("sidebar-wrapper").classList.toggle("active");
  });
     if (document.getElementById("sidebar-wrapper").classList.contains("active")) {
             document.getElementById("sidebar-wrapper").style.marginLeft = "260px";
        } else {
            document.getElementById("sidebar-wrapper").style.marginLeft = "0";
        }
 
  </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>