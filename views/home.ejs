<!doctype html>
<html lang="en">

<head>
  <title> Book Your Show</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #071a42; 
      color: #ffffff;
    }

    
    .navbar {
      background-color: rgba(15, 23, 42, 0.95) !important;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .navbar-brand {
      font-weight: 700;
      letter-spacing: 1px;
      color: #ef4444 !important;
    }

    
    .hero-section {
      height: 60vh;
      background: linear-gradient(to bottom, rgba(15, 23, 42, 0.3), #0f172a),
      url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-4.0.3&auto=format&fit=crop&w=1470&q=80');
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 800;
      text-shadow: 2px 4px 10px rgba(0, 0, 0, 0.5);
    }

    
    .movie-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      overflow: hidden;
      height: 100%;
    }

    .movie-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
      border-color: #ca5f5f;
    }

    .card-img-container {
      position: relative;
      overflow: hidden;
    }

    .movie-poster {
      height: 350px;
      object-fit: cover;
      width: 100%;
      transition: transform 0.5s ease;
    }

    .movie-card:hover .movie-poster {
      transform: scale(1.1);
    }

    .genre-badge {
      position: absolute;
      top: 15px;
      left: 15px;
      background: #ef4444;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .btn-book {
      background-color: #ef4444;
      border: none;
      font-weight: 600;
      padding: 10px 20px;
      border-radius: 8px;
      transition: 0.3s;
    }

    .btn-book:hover {
      background-color: #dc2626;
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
    }

    .footer {
      padding: 40px 0;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-top: 50px;
      color: #94a3b8;
    }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
      <div class="container">
        <a class="navbar-brand" href="/home"><i class="fa-solid fa-film me-2"></i>CINEMA</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navId">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navId">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link active" href="/home">Movies</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/movies/booking">History</a>
            </li>
          </ul>
          <div class="d-flex align-items-center">
            <a href="/logout" class="btn btn-outline-light btn-sm px-4 rounded-pill">Logout</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <section class="hero-section">
      <div class="container">
        <h1 class="hero-title">Experience Cinema Like Never Before</h1>
        <p class="lead mb-4">Grab your tickets for the latest blockbusters in just a few clicks.</p>
        <a href="#movies-list" class="btn btn-danger btn-lg px-5 rounded-pill">View All Shows</a>
      </div>
    </section>

    <div class="container py-5" id="movies-list">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Now Showing</h2>
        <span class="text-muted">Explore <%= movies.length %> movies</span>
      </div>

      <div class="row g-4">
        <% if (movies && movies.length > 0) { %>
          <% movies.forEach(mov => { %>
            <div class="col-sm-6 col-md-4 col-lg-3">
              <div class="card movie-card text-white">
                <div class="card-img-container">
                  <img src="<%= mov.poster %>" class="movie-poster" alt="<%= mov.title %>">
                  <span class="genre-badge text-uppercase"><%= mov.genre %></span>
                </div>
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title fw-bold mb-1"><%= mov.title %></h5>
                  <p class="text-muted small mb-2"><i class="fa-regular fa-clock me-1"></i> <%= mov.duration %> mins</p>
                  <p class="card-text text-secondary small flex-grow-1">
                    <%= mov.description.substring(0, 80) %>...
                  </p>
                  <a href="/movies/shows/<%=mov._id %>" class="btn btn-book text-white mt-3 w-100">
                    Book Tickets
                  </a>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <i class="fa-solid fa-clapperboard display-1 text-muted mb-3"></i>
            <p class="fs-4 text-muted">No movies available right now. Check back soon!</p>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <footer class="footer text-center">
    <div class="container">
      <p class="mb-0">&copy; 2026 Cinema Bookings. All rights reserved.</p>
      <div class="mt-2">
        <i class="fab fa-facebook mx-2"></i>
        <i class="fab fa-twitter mx-2"></i>
        <i class="fab fa-instagram mx-2"></i>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>