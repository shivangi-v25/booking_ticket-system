<!doctype html>
<html lang="en">

<head>
  <title>All Shows | CinePass</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

  <style>
    /* Consistent Cinema Background */
    body {
      background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
      color: #ffffff;
      min-height: 100vh;
      font-family: sans-serif;
    }

    /* Simple Glass Effect */
    .glass-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 15px;
      transition: transform 0.2s; /* Smooth small pop on hover */
    }

    .glass-card:hover {
      transform: scale(1.02);
      border-color: #ef4444;
    }

    .show-poster {
      height: 200px;
      object-fit: cover;
      border-radius: 15px 15px 0 0;
    }

    .navbar {
      background-color: rgba(15, 23, 42, 0.9) !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-sm navbar-dark mb-4">
      <div class="container">
        <a class="navbar-brand fw-bold text-danger" href="/home">
            <i class="fa-solid fa-film me-2"></i>CINEPASS
        </a>
        <div class="collapse navbar-collapse" id="collapsibleNavId">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link" href="/movies/booking">History</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <div class="container my-4">
      <h2 class="text-center mb-5 fw-bold text-uppercase tracking-wider">Available Shows</h2>
      
      <div class="row g-4">
        <% if (shows && shows.length > 0) { %>
          <% shows.forEach(show => { %>
            <div class="col-sm-6 col-md-4 col-lg-3">
              <div class="card glass-card h-100 text-white border-0 shadow">
                <% if (show.movie && show.movie.poster) { %>
                  <img src="<%= show.movie.poster %>" class="show-poster" alt="Poster">
                <% } %>
                
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title fw-bold mb-1 text-truncate">
                    <%= show.movie ? show.movie.title : "Movie Deleted" %>
                  </h5>
                  
                  <div class="card-text small mb-3">
                    <p class="mb-1 text-muted">
                        <i class="fa-regular fa-calendar me-2"></i><%= new Date(show.date).toLocaleDateString('en-GB') %>
                    </p>
                    <p class="mb-1 text-muted">
                        <i class="fa-regular fa-clock me-2"></i><%= show.time %>
                    </p>
                    <p class="mb-1">
                        <span class="text-danger fw-bold">Seats:</span> <%= show.availableSeats %>
                    </p>
                  </div>

                  <div class="mt-auto d-flex justify-content-between align-items-center">
                    <span class="fs-5 fw-bold text-success">$<%= show.price %></span>
                    <form action="/movies/bookShow/<%=show._id %>">
                      <button type="submit" class="btn btn-danger btn-sm px-4 rounded-pill">Book</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <p class="text-muted fs-4">No shows available right now.</p>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>